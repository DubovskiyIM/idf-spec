{
  "_meta": {
    "specVersion": "0.1",
    "manifestSha256": "6f204b7f139fcdfea9144b84c5c226d45a6e1e38fe8cd09763473b43d3f3e6fb",
    "description": "7 intent'ов library-домена. Все эффекты — minimal (kind + entity); fields заполняются при confirm из form data + viewer context."
  },
  "intents": [
    {
      "id": "add_book",
      "ownerRole": "librarian",
      "requiredFields": [
        { "name": "title",  "type": "string" },
        { "name": "author", "type": "string" }
      ],
      "effects": [{ "kind": "create", "entity": "Book" }]
    },
    {
      "id": "remove_book",
      "ownerRole": "librarian",
      "requiredFields": [{ "name": "id", "type": "string" }],
      "effects": [{ "kind": "remove", "entity": "Book" }]
    },
    {
      "id": "update_book_metadata",
      "ownerRole": "librarian",
      "requiredFields": [
        { "name": "id",     "type": "string" },
        { "name": "title",  "type": "string" },
        { "name": "author", "type": "string" }
      ],
      "effects": [{ "kind": "replace", "entity": "Book" }]
    },
    {
      "id": "register_user",
      "ownerRole": "librarian",
      "requiredFields": [{ "name": "name", "type": "string" }],
      "effects": [{ "kind": "create", "entity": "User" }]
    },
    {
      "id": "borrow_book",
      "ownerRole": "reader",
      "requiredFields": [{ "name": "bookId", "type": "string" }],
      "effects": [{ "kind": "create", "entity": "Loan" }]
    },
    {
      "id": "return_book",
      "ownerRole": "reader",
      "requiredFields": [{ "name": "id", "type": "string" }],
      "effects": [{ "kind": "transition", "entity": "Loan" }]
    },
    {
      "id": "cancel_loan",
      "ownerRole": "librarian",
      "requiredFields": [{ "name": "id", "type": "string" }],
      "effects": [{ "kind": "remove", "entity": "Loan" }]
    }
  ]
}
